# Groq LLM access
GROQ_API_KEY=your_groq_key_here

# LangSmith tracing and evaluation
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_key_here
LANGCHAIN_PROJECT=Phase4_Research_Agent

# Capstone API authentication
AEGIS_API_KEY=your_aegis_api_key_here

# Capstone Streamlit frontend backend URL
AEGIS_API_BASE_URL=http://127.0.0.1:8001

# Groq model override (optional)
AEGIS_GROQ_MODEL=llama-3.3-70b-versatile

# Dynamic LLM Provider configuration (GROQ or VLLM)
LLM_PROVIDER=GROQ
VLLM_URL=http://vllm:8001/v1
